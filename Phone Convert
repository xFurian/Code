# =========================================
# Phone Auth Discovery + SMS Default Sign-In Conversion
# Phase 1: Discover & categorize all users (ACTIVE ONLY) + detect phone number collisions
# Phase 2: Convert eligible users, export failures
# Requires: Microsoft.Graph modules + ImportExcel (optional, falls back to CSV)
# =========================================

Import-Module Microsoft.Graph.Identity.SignIns
Import-Module Microsoft.Graph.Users.Actions

# --- Single connection with all required scopes ---
Connect-MgGraph -Scopes @(
    "UserAuthenticationMethod.Read.All",
    "UserAuthenticationMethod.ReadWrite.All",
    "User.Read.All"
)

# --- Output paths ---
$timestamp       = Get-Date -Format 'yyyyMMdd_HHmm'
$reportPath      = "C:\PhoneAuth_FullReport_$timestamp.xlsx"
$failurePath     = "C:\PhoneAuth_Failures_$timestamp.xlsx"
$useExcel        = $null -ne (Get-Module -ListAvailable -Name ImportExcel)

if (-not $useExcel) {
    Write-Host "ImportExcel module not found. Output will fall back to CSV." -ForegroundColor Yellow
    $reportPath  = $reportPath  -replace '\.xlsx$', '.csv'
    $failurePath = $failurePath -replace '\.xlsx$', '.csv'
}

# --- Collections ---
$allResults      = [System.Collections.Generic.List[PSCustomObject]]::new()
$eligible        = [System.Collections.Generic.List[PSCustomObject]]::new()  # Can be converted to SMS
$willFail        = [System.Collections.Generic.List[PSCustomObject]]::new()  # Will error on conversion
$changeSuccess   = [System.Collections.Generic.List[PSCustomObject]]::new()
$changeFailure   = [System.Collections.Generic.List[PSCustomObject]]::new()

# --- Collision tracking (SMS-capable numbers across ACTIVE users) ---
$smsNumberToUsers = @{}   # key = normalized phone number, value = List[PSCustomObject]{UPN, DisplayName, UserId}
$collisionReport  = [System.Collections.Generic.List[PSCustomObject]]::new()

function Normalize-PhoneNumber {
    param([string]$Number)

    if ([string]::IsNullOrWhiteSpace($Number)) { return $null }

    $n = $Number.Trim()
    $hasPlus = $n.StartsWith('+')

    # strip everything except digits
    $digits = ($n -replace '[^\d]', '')
    if ([string]::IsNullOrWhiteSpace($digits)) { return $null }

    if ($hasPlus) { return "+$digits" }
    return $digits
}

# =============================================
# PHASE 1 — DISCOVERY (ACTIVE ONLY)
# =============================================
Write-Host "`n===== PHASE 1: DISCOVERY =====" -ForegroundColor Cyan
Write-Host "Retrieving all users..." -ForegroundColor Cyan

$allUsers = Get-MgUser -All -Property Id, DisplayName, UserPrincipalName, OfficeLocation, JobTitle, Department, AccountEnabled

$activeUsers   = $allUsers | Where-Object { $_.AccountEnabled -eq $true }
$disabledUsers = $allUsers | Where-Object { $_.AccountEnabled -ne $true }

Write-Host "`n--- ACCOUNT STATUS ---" -ForegroundColor Cyan
Write-Host "Total users in tenant:  $($allUsers.Count)"       -ForegroundColor White
Write-Host "Active (enabled):       $($activeUsers.Count)"   -ForegroundColor Green
Write-Host "Disabled (skipped):     $($disabledUsers.Count)" -ForegroundColor Yellow
Write-Host "Processing ACTIVE accounts only.`n"              -ForegroundColor Cyan

$users   = $activeUsers
$total   = $users.Count
$counter = 0

foreach ($user in $users) {
    $counter++
    Write-Progress -Activity "Discovering phone auth methods (ACTIVE users)" `
                   -Status "$counter of $total — $($user.UserPrincipalName)" `
                   -PercentComplete (($counter / $total) * 100)

    try {
        $phoneMethods = Get-MgUserAuthenticationPhoneMethod -UserId $user.Id -ErrorAction Stop

        if (-not $phoneMethods) {
            # No phone methods registered at all
            $entry = [PSCustomObject]@{
                UserPrincipalName      = $user.UserPrincipalName
                DisplayName            = $user.DisplayName
                Department             = $user.Department
                JobTitle               = $user.JobTitle
                AccountEnabled         = $user.AccountEnabled
                PhoneType              = "None"
                PhoneNumber            = "N/A"
                SMSCapable             = "No"
                VoiceCapable           = "No"
                OfficePhonePresent     = "No"
                MobilePhonePresent     = "No"
                RegisteredMethod       = "None Registered"
                SupportStatus          = "Not Configured"
                ConversionEligible     = "No"
                FailureReason          = "No phone authentication method registered"
                Collision              = "No"
                CollisionPhoneNumber   = ""
            }
            $allResults.Add($entry)
            $willFail.Add($entry)
            continue
        }

        # Track SMS-capable numbers for collision detection (mobile/alternateMobile only)
        $smsCapableMethods = $phoneMethods | Where-Object { $_.PhoneType -in @("mobile","alternateMobile") }

        foreach ($pm in $smsCapableMethods) {
            $norm = Normalize-PhoneNumber $pm.PhoneNumber
            if (-not $norm) { continue }

            if (-not $smsNumberToUsers.ContainsKey($norm)) {
                $smsNumberToUsers[$norm] = [System.Collections.Generic.List[object]]::new()
            }

            # Deduplicate per number/user
            if (-not ($smsNumberToUsers[$norm] | Where-Object { $_.UserPrincipalName -eq $user.UserPrincipalName })) {
                $smsNumberToUsers[$norm].Add([PSCustomObject]@{
                    UserPrincipalName = $user.UserPrincipalName
                    DisplayName       = $user.DisplayName
                    UserId            = $user.Id
                })
            }
        }

        # Determine if this user has at least one SMS-capable (mobile/alternateMobile) method
        $hasMobile = $phoneMethods | Where-Object { $_.PhoneType -in @("mobile", "alternateMobile") }

        foreach ($method in $phoneMethods) {
            $phoneType  = $method.PhoneType
            $smsCapable = $phoneType -in @("mobile", "alternateMobile")

            $registeredMethod = if ($smsCapable) { "SMS + Voice" } else { "Voice Only" }

            $supportStatus = switch ($phoneType) {
                "mobile"          { "Supported (Mobile)" }
                "alternateMobile" { "Supported (Alternate Mobile)" }
                "office"          { "Limited (Voice Only — No SMS)" }
                default           { "Unknown" }
            }

            # Eligibility is per-user (not per-method): user needs at least one mobile/altMobile method
            $isEligible = [bool]$hasMobile
            $failReason = if (-not $isEligible) { "No mobile phone method — voice/office only" } else { "" }

            $entry = [PSCustomObject]@{
                UserPrincipalName      = $user.UserPrincipalName
                DisplayName            = $user.DisplayName
                Department             = $user.Department
                JobTitle               = $user.JobTitle
                AccountEnabled         = $user.AccountEnabled
                PhoneType              = $phoneType
                PhoneNumber            = $method.PhoneNumber
                SMSCapable             = if ($smsCapable) { "Yes" } else { "No" }
                VoiceCapable           = "Yes"
                OfficePhonePresent     = if ($phoneType -eq "office") { "Yes" } else { "No" }
                MobilePhonePresent     = if ($phoneType -in @("mobile","alternateMobile")) { "Yes" } else { "No" }
                RegisteredMethod       = $registeredMethod
                SupportStatus          = $supportStatus
                ConversionEligible     = if ($isEligible) { "Yes" } else { "No" }
                FailureReason          = $failReason

                # Collision fields are populated after all users are processed
                Collision              = "No"
                CollisionPhoneNumber   = ""
            }
            $allResults.Add($entry)
        }

        # Add to eligible or willFail (deduplicate per user)
        if ($hasMobile) {
            if (-not ($eligible | Where-Object { $_.UserPrincipalName -eq $user.UserPrincipalName })) {
                $eligible.Add([PSCustomObject]@{
                    UserPrincipalName = $user.UserPrincipalName
                    DisplayName       = $user.DisplayName
                    UserId            = $user.Id
                })
            }
        } else {
            if (-not ($willFail | Where-Object { $_.UserPrincipalName -eq $user.UserPrincipalName })) {
                $willFail.Add(($allResults | Where-Object { $_.UserPrincipalName -eq $user.UserPrincipalName } | Select-Object -First 1))
            }
        }
    }
    catch {
        $entry = [PSCustomObject]@{
            UserPrincipalName      = $user.UserPrincipalName
            DisplayName            = $user.DisplayName
            Department             = $user.Department
            JobTitle               = $user.JobTitle
            AccountEnabled         = $user.AccountEnabled
            PhoneType              = "ERROR"
            PhoneNumber            = "N/A"
            SMSCapable             = "N/A"
            VoiceCapable           = "N/A"
            OfficePhonePresent     = "N/A"
            MobilePhonePresent     = "N/A"
            RegisteredMethod       = "Query Failed"
            SupportStatus          = "Error"
            ConversionEligible     = "No"
            FailureReason          = $_.Exception.Message
            Collision              = "N/A"
            CollisionPhoneNumber   = ""
        }
        $allResults.Add($entry)
        $willFail.Add($entry)
    }
}
Write-Progress -Activity "Discovering phone auth methods (ACTIVE users)" -Completed

# --- Collision computation (after discovery) ---
$collisionNumbers = $smsNumberToUsers.Keys | Where-Object { $smsNumberToUsers[$_].Count -gt 1 }

$distinctSmsNumbers   = $smsNumberToUsers.Keys.Count
$collisionNumberCount = $collisionNumbers.Count
$collisionUserCount   = (
    $collisionNumbers |
    ForEach-Object { $smsNumberToUsers[$_].UserPrincipalName } |
    Select-Object -Unique
).Count

# Build a collision report (one row per duplicated phone number)
foreach ($num in $collisionNumbers) {
    $usersForNum = $smsNumberToUsers[$num]
    $collisionReport.Add([PSCustomObject]@{
        CollisionPhoneNumber = $num
        UserCount            = $usersForNum.Count
        Users                = ($usersForNum | ForEach-Object { "$($_.UserPrincipalName) ($($_.DisplayName))" }) -join "; "
    })
}

# Build a set of UPNs impacted by collision (active users)
$collisionUserSet = New-Object System.Collections.Generic.HashSet[string]
foreach ($num in $collisionNumbers) {
    foreach ($u in $smsNumberToUsers[$num]) {
        [void]$collisionUserSet.Add($u.UserPrincipalName)
    }
}

# Apply collision flags to each report row
foreach ($row in $allResults) {
    $isCollisionUser = $collisionUserSet.Contains($row.UserPrincipalName)

    $row.Collision = if ($isCollisionUser) { "Yes" } else { "No" }

    if ($row.SMSCapable -eq "Yes") {
        $normRow = Normalize-PhoneNumber $row.PhoneNumber
        if ($normRow -and ($collisionNumbers -contains $normRow)) {
            $row.CollisionPhoneNumber = $normRow
        } else {
            $row.CollisionPhoneNumber = ""
        }
    } else {
        $row.CollisionPhoneNumber = ""
    }
}

# --- Phase 1 Summary ---
Write-Host "`n--- DISCOVERY SUMMARY ---" -ForegroundColor Cyan
Write-Host "Total users in tenant:            $($allUsers.Count)"      -ForegroundColor White
Write-Host "Active accounts scanned:          $($activeUsers.Count)"   -ForegroundColor White
Write-Host "Disabled accounts (skipped):      $($disabledUsers.Count)" -ForegroundColor DarkGray
Write-Host "Eligible for SMS conversion:      $($eligible.Count)"      -ForegroundColor Green
Write-Host "Will FAIL conversion:             $($willFail.Count)"      -ForegroundColor Red
Write-Host "Distinct SMS-capable numbers:     $distinctSmsNumbers"     -ForegroundColor White
Write-Host "Collision phone numbers:          $collisionNumberCount"   -ForegroundColor Magenta
Write-Host "Users impacted by collisions:     $collisionUserCount"     -ForegroundColor Magenta

if ($collisionReport.Count -gt 0) {
    Write-Host "`n--- COLLISIONS (duplicate SMS-capable phone numbers) ---" -ForegroundColor Magenta
    $collisionReport | Sort-Object UserCount -Descending | Format-Table CollisionPhoneNumber, UserCount, Users -AutoSize
}

if ($willFail.Count -gt 0) {
    Write-Host "`nUsers that will FAIL:" -ForegroundColor Yellow
    $willFail | Format-Table UserPrincipalName, DisplayName, PhoneType, FailureReason -AutoSize
}

if ($eligible.Count -gt 0) {
    Write-Host "`nUsers eligible for conversion:" -ForegroundColor Green
    $eligible | Format-Table UserPrincipalName, DisplayName -AutoSize
}

# --- Export full discovery report ---
$sortedResults = $allResults | Sort-Object UserPrincipalName

if ($useExcel) {
    $redStyle        = New-ConditionalText "Not Configured" -BackgroundColor "#FFD7D7"
    $yellowStyle     = New-ConditionalText "Limited"        -BackgroundColor "#FFF3CD"
    $greenStyle      = New-ConditionalText "Supported"      -BackgroundColor "#D4EDDA"
    $noStyle         = New-ConditionalText "No"             -BackgroundColor "#FFD7D7"
    $collisionStyle  = New-ConditionalText "Yes"            -BackgroundColor "#F8D7DA" -ConditionalTextColor "#721C24"

    $sortedResults | Export-Excel -Path $reportPath `
        -WorksheetName "PhoneAuthMethods" `
        -TableName "PhoneAuth" `
        -TableStyle Medium6 `
        -AutoSize `
        -FreezeTopRow `
        -ConditionalText $redStyle, $yellowStyle, $greenStyle, $noStyle, $collisionStyle

    # Export collisions worksheet
    if ($collisionReport.Count -gt 0) {
        $collisionReport | Export-Excel -Path $reportPath `
            -WorksheetName "Collisions" `
            -TableName "SMSPhoneCollisions" `
            -TableStyle Medium6 `
            -AutoSize `
            -FreezeTopRow `
            -Append
    }
} else {
    $sortedResults | Export-Csv -Path $reportPath -NoTypeInformation

    if ($collisionReport.Count -gt 0) {
        $collisionPath = $reportPath -replace '\.csv$', '_Collisions.csv'
        $collisionReport | Export-Csv -Path $collisionPath -NoTypeInformation
        Write-Host "Collision report exported: $collisionPath" -ForegroundColor Magenta
    }
}
Write-Host "`nFull discovery report exported: $reportPath" -ForegroundColor Green

# =============================================
# PHASE 2 — CONVERSION (with confirmation)
# =============================================
if ($eligible.Count -eq 0) {
    Write-Host "`nNo eligible users found. Nothing to convert. Exiting." -ForegroundColor Yellow
    Disconnect-MgGraph
    return
}

Write-Host "`n===== PHASE 2: CONVERSION =====" -ForegroundColor Cyan
$confirm = Read-Host "Proceed with SMS default conversion for $($eligible.Count) eligible users? (Y/N)"

if ($confirm -notin @("Y", "y", "Yes", "yes")) {
    Write-Host "Conversion cancelled by user. Discovery report still saved." -ForegroundColor Yellow
    Disconnect-MgGraph
    return
}

$convCounter = 0
$convTotal   = $eligible.Count

foreach ($target in $eligible) {
    $convCounter++
    Write-Progress -Activity "Converting default sign-in to SMS" `
                   -Status "$convCounter of $convTotal — $($target.UserPrincipalName)" `
                   -PercentComplete (($convCounter / $convTotal) * 100)

    try {
        $body = @{
            userPreferredMethodForSecondaryAuthentication = "sms"
        } | ConvertTo-Json

        Invoke-MgGraphRequest -Method PATCH `
            -Uri "https://graph.microsoft.com/beta/users/$($target.UserId)/authentication/signInPreferences" `
            -Body $body `
            -ContentType "application/json"

        $changeSuccess.Add([PSCustomObject]@{
            UserPrincipalName = $target.UserPrincipalName
            DisplayName       = $target.DisplayName
            Status            = "Success"
            Error             = ""
        })
    }
    catch {
        $changeFailure.Add([PSCustomObject]@{
            UserPrincipalName = $target.UserPrincipalName
            DisplayName       = $target.DisplayName
            Status            = "Failed"
            Error             = $_.Exception.Message
        })
    }
}
Write-Progress -Activity "Converting default sign-in to SMS" -Completed

# --- Phase 2 Summary ---
Write-Host "`n--- CONVERSION SUMMARY ---" -ForegroundColor Cyan
Write-Host "Successfully converted:  $($changeSuccess.Count)" -ForegroundColor Green
Write-Host "Failed during conversion: $($changeFailure.Count)" -ForegroundColor Red

# --- Export failure report (discovery failures + conversion failures combined) ---
$allFailures = [System.Collections.Generic.List[PSCustomObject]]::new()

foreach ($f in $willFail) {
    $allFailures.Add([PSCustomObject]@{
        UserPrincipalName = $f.UserPrincipalName
        DisplayName       = $f.DisplayName
        FailureStage      = "Discovery — Not Eligible"
        Reason            = $f.FailureReason
    })
}
foreach ($f in $changeFailure) {
    $allFailures.Add([PSCustomObject]@{
        UserPrincipalName = $f.UserPrincipalName
        DisplayName       = $f.DisplayName
        FailureStage      = "Conversion — Runtime Error"
        Reason            = $f.Error
    })
}

if ($allFailures.Count -gt 0) {
    if ($useExcel) {
        $allFailures | Export-Excel -Path $failurePath `
            -WorksheetName "Failures" `
            -TableName "FailedUsers" `
            -TableStyle Medium6 `
            -AutoSize `
            -FreezeTopRow
    } else {
        $allFailures | Export-Csv -Path $failurePath -NoTypeInformation
    }
    Write-Host "`nFailure report exported: $failurePath" -ForegroundColor Yellow
}

if ($changeSuccess.Count -gt 0) {
    Write-Host "`nSuccessfully converted users:" -ForegroundColor Green
    $changeSuccess | Format-Table UserPrincipalName, DisplayName, Status -AutoSize
}

if ($changeFailure.Count -gt 0) {
    Write-Host "`nFailed conversion users:" -ForegroundColor Red
    $changeFailure | Format-Table UserPrincipalName, DisplayName, Error -AutoSize
}

Disconnect-MgGraph
Write-Host "`nDone." -ForegroundColor Cyan
``
