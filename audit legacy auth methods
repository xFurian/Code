# Note: This script can take a long time to run depending on sign-in volume and retention.

<#
.SYNOPSIS
    Audits legacy authentication usage from Microsoft Entra ID sign-in logs.

.DESCRIPTION
    Pulls interactive and non-interactive user sign-in logs filtered to Microsoft-documented
    legacy authentication client app values using Microsoft Graph REST calls.

    Microsoft Graph signIn.clientAppUsed documents legacy authentication clients as:
    Exchange ActiveSync, IMAP, MAPI, SMTP, POP, and other clients.

.NOTES
    Requires:
      - Microsoft Entra ID P1 or P2 for sign-in log access through Microsoft Graph
      - Microsoft.Graph.Authentication PowerShell module

    Delegated Graph permissions:
      - AuditLog.Read.All
      - Directory.Read.All

    Least-privileged Microsoft Entra roles for delegated access include:
      - Global Reader
      - Reports Reader
      - Security Administrator
      - Security Operator
      - Security Reader

    Non-interactive user sign-in query uses Microsoft Graph beta because this script filters
    on signInEventTypes for nonInteractiveUser.
#>

# Disable WAM before module loads
$env:MSAL_ENABLE_WAM = "0"

try {
    Import-Module Microsoft.Graph.Authentication -ErrorAction Stop
}
catch {
    Write-Error "Microsoft.Graph.Authentication module not found. Install it with:"
    Write-Host "  Install-Module Microsoft.Graph.Authentication -Force -Scope CurrentUser" -ForegroundColor Yellow
    return
}

# Configuration
$DaysBack   = 30
$ExportPath = Join-Path $env:USERPROFILE "Desktop\LegacyAuthAudit_$(Get-Date -Format 'yyyyMMdd_HHmmss').csv"

# Microsoft Graph documented legacy authentication clientAppUsed values
$LegacyClientApps = @(
    "Exchange ActiveSync",
    "IMAP",
    "MAPI",
    "SMTP",
    "POP",
    "other clients"
)

# Connect
Write-Host "`n[*] Connecting to Microsoft Graph..." -ForegroundColor Cyan

try {
    Connect-MgGraph -Scopes "AuditLog.Read.All","Directory.Read.All" -NoWelcome -ErrorAction Stop
}
catch {
    Write-Warning "Interactive browser auth failed. Falling back to device code..."
    try {
        Connect-MgGraph -Scopes "AuditLog.Read.All","Directory.Read.All" -UseDeviceCode -NoWelcome -ErrorAction Stop
    }
    catch {
        Write-Error "All authentication methods failed: $($_.Exception.Message)"
        return
    }
}

$Context = Get-MgContext
if (-not $Context) {
    Write-Error "Graph context is null. Authentication did not complete. Exiting."
    return
}

Write-Host "[✓] Connected as: $($Context.Account)" -ForegroundColor Green
Write-Host "    Scopes: $($Context.Scopes -join ', ')" -ForegroundColor Gray

# Validate token
Write-Host "[*] Validating Graph session..." -ForegroundColor Cyan
try {
    $null = Invoke-MgGraphRequest -Method GET -Uri "https://graph.microsoft.com/v1.0/me" -OutputType PSObject -ErrorAction Stop
    Write-Host "[✓] Token validated.`n" -ForegroundColor Green
}
catch {
    Write-Error "Token validation failed: $($_.Exception.Message)"
    if (Get-MgContext) { Disconnect-MgGraph | Out-Null }
    return
}

function New-ODataStringLiteral {
    param(
        [Parameter(Mandatory)]
        [string] $Value
    )

    return "'" + ($Value -replace "'", "''") + "'"
}

function New-ClientAppUsedFilter {
    param(
        [Parameter(Mandatory)]
        [string[]] $ClientApps
    )

    $Conditions = foreach ($ClientApp in $ClientApps) {
        "clientAppUsed eq $(New-ODataStringLiteral -Value $ClientApp)"
    }

    return "(" + ($Conditions -join " or ") + ")"
}

function Get-AllGraphResults {
    param(
        [Parameter(Mandatory)]
        [string] $Uri,

        [string] $Label = "records",

        [int] $MaxPages = 0
    )

    $Results   = New-Object System.Collections.Generic.List[object]
    $PageCount = 0
    $SeenNext  = New-Object 'System.Collections.Generic.HashSet[string]'

    try {
        $Response = Invoke-MgGraphRequest -Method GET -Uri $Uri -OutputType PSObject -ErrorAction Stop

        while ($true) {
            $PageCount++

            if ($Response.value) {
                foreach ($Item in $Response.value) {
                    [void] $Results.Add($Item)
                }
            }

            Write-Progress -Activity "Retrieving $Label from Microsoft Graph" `
                           -Status  ("Pages: {0} | Items: {1}" -f $PageCount, $Results.Count) `
                           -PercentComplete -1

            if ($MaxPages -gt 0 -and $PageCount -ge $MaxPages) {
                Write-Warning "MaxPages ($MaxPages) reached. Stopping pagination early."
                break
            }

            $NextLink = $Response.'@odata.nextLink'
            if (-not $NextLink) {
                break
            }

            if (-not $SeenNext.Add($NextLink)) {
                Write-Warning "Detected repeating @odata.nextLink. Stopping to prevent infinite loop."
                break
            }

            $Response = Invoke-MgGraphRequest -Method GET -Uri $NextLink -OutputType PSObject -ErrorAction Stop
        }

        Write-Progress -Activity "Retrieving $Label from Microsoft Graph" -Completed
    }
    catch {
        Write-Progress -Activity "Retrieving $Label from Microsoft Graph" -Completed
        Write-Warning "Graph request failed while retrieving $Label: $($_.Exception.Message)"
    }

    return $Results
}

function Convert-SignInToLegacyAuthRecord {
    param(
        [Parameter(Mandatory)]
        [object] $Log,

        [Parameter(Mandatory)]
        [ValidateSet("Interactive", "NonInteractive")]
        [string] $SignInType
    )

    [PSCustomObject]@{
        SignInType          = $SignInType
        CreatedDateTime     = $Log.createdDateTime
        UserDisplayName     = $Log.userDisplayName
        UserPrincipalName   = $Log.userPrincipalName
        ClientAppUsed       = $Log.clientAppUsed
        ResourceDisplayName = $Log.resourceDisplayName
        ResourceId          = $Log.resourceId
        AppDisplayName      = $Log.appDisplayName
        IPAddress           = $Log.ipAddress
        StatusErrorCode     = $Log.status.errorCode
        FailureReason       = $Log.status.failureReason
        AdditionalDetails   = $Log.status.additionalDetails
    }
}

# Build filter date
$FilterDate = (Get-Date).AddDays(-$DaysBack).ToUniversalTime().ToString("yyyy-MM-ddTHH:mm:ssZ")

# Reduce payload size for faster paging
$Select = "createdDateTime,userDisplayName,userPrincipalName,clientAppUsed,resourceDisplayName,resourceId,appDisplayName,ipAddress,status"

# Build Microsoft Graph-aligned client app filter
$ClientAppFilter = New-ClientAppUsedFilter -ClientApps $LegacyClientApps

# Pull interactive legacy sign-ins
Write-Host "[*] Pulling interactive legacy authentication sign-in logs ($DaysBack days)..." -ForegroundColor Cyan

$InteractiveFilter = "createdDateTime ge $FilterDate and $ClientAppFilter"
$InteractiveUri = "https://graph.microsoft.com/v1.0/auditLogs/signIns?`$filter=$([uri]::

$InteractiveLogs = Get-AllGraphResults -Uri $InteractiveUri -Label "interactive legacy authentication events"
Write-Host "    Total: $($InteractiveLogs.Count) interactive legacy authentication sign-in events." -ForegroundColor Gray

# Pull non-interactive legacy sign-ins
Write-Host "[*] Pulling non-interactive legacy authentication sign-in logs ($DaysBack days)..." -ForegroundColor Cyan

$NonInteractiveFilter = "createdDateTime ge $FilterDate and signInEventTypes/any(t: t eq 'nonInteractiveUser') and $ClientAppFilter"
$NonInteractiveUri = "https://graph.microsoft.com/beta/auditLogs/signIns?`$filter=$([uri]::

$NonInteractiveLogs = Get-AllGraphResults -Uri $NonInteractiveUri -Label "non-interactive legacy authentication events"
Write-Host "    Total: $($NonInteractiveLogs.Count) non-interactive legacy authentication sign-in events." -ForegroundColor Gray

# Convert results
Write-Host "`n[*] Preparing export data..." -ForegroundColor Cyan

$AllSignIns = New-Object System.Collections.Generic.List[object]

foreach ($Log in $InteractiveLogs) {
    [void] $AllSignIns.Add((Convert-SignInToLegacyAuthRecord -Log $Log -SignInType "Interactive"))
}

foreach ($Log in $NonInteractiveLogs) {
    [void] $AllSignIns.Add((Convert-SignInToLegacyAuthRecord -Log $Log -SignInType "NonInteractive"))
}

# Case-insensitive safety check in case Graph returns mixed casing for other clients
$LegacyClientSet = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
foreach ($ClientApp in $LegacyClientApps) {
    [void] $LegacyClientSet.Add($ClientApp)
}

$AllSignIns = @(
    foreach ($SignIn in $AllSignIns) {
        if ($SignIn.ClientAppUsed -and $LegacyClientSet.Contains($SignIn.ClientAppUsed)) {
            $SignIn
        }
    }
)

Write-Host "[✓] Legacy authentication sign-in events found: $($AllSignIns.Count)" -ForegroundColor Yellow

if ($AllSignIns.Count -eq 0) {
    Write-Host "`n[✓] No legacy authentication usage detected in the last $DaysBack days." -ForegroundColor Green
    if (Get-MgContext) { Disconnect-MgGraph | Out-Null }
    return
}

# Export raw detail
$ExportDir = Split-Path -Path $ExportPath -Parent
if (-not (Test-Path $ExportDir)) {
    New-Item -ItemType Directory -Path $ExportDir | Out-Null
}

$AllSignIns |
    Sort-Object CreatedDateTime -Descending |
    Export-Csv -Path $ExportPath -NoTypeInformation -Encoding UTF8

Write-Host "`n[✓] Raw detail exported to: $ExportPath" -ForegroundColor Green

# Optional console summary
Write-Host "`nSummary by ClientAppUsed:" -ForegroundColor Cyan
$AllSignIns |
    Group-Object ClientAppUsed |
    Sort-Object Count -Descending |
    Select-Object Count, Name |
    Format-Table -AutoSize

Write-Host "`nSummary by SignInType:" -ForegroundColor Cyan
$AllSignIns |
    Group-Object SignInType |
    Sort-Object Count -Descending |
    Select-Object Count, Name |
    Format-Table -AutoSize

if (Get-MgContext) {
    Disconnect-MgGraph | Out-Null
}

Write-Host "[✓] Complete.`n" -ForegroundColor Green
