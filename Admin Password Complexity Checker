<# AD Password Policy / FGPP Checker #>

Import-Module ActiveDirectory -ErrorAction Stop

function Pause-Menu {
    Write-Host ""
    Read-Host "Press Enter to return to the menu"
}

function Get-OptionalServer {
    $Server = Read-Host "Domain Controller name/FQDN, or press Enter to auto-select"
    if ($Server) { return @{ Server = $Server } }
    return @{}
}

function Show-Help {
    Clear-Host
    Write-Host "How to use" -ForegroundColor Cyan
    Write-Host "----------"
    Write-Host "User: Enter the AD logon name, such as testuser1 or svc-testaccount."
    Write-Host "Domain Controller: Leave blank first. If needed, enter a DC such as DC01.contoso.com."
    Write-Host "FGPP/PSO: Password policy object name, such as Admin Password Policy."
    Write-Host "Target Group: Group listed under 'Directly Applies To', such as AdminPasswordPolicyUsers."
    Write-Host ""
    Write-Host "Tip: If a specific DC fails, leave the DC field blank or try another DC."
    Pause-Menu
}

function Test-DC {
    Clear-Host
    $Server = Read-Host "Enter Domain Controller name/FQDN"

    if (-not $Server) {
        Write-Warning "No Domain Controller entered."
        Pause-Menu
        return
    }

    Write-Host "`nTesting AD PowerShell connectivity to $Server on TCP 9389..." -ForegroundColor Yellow

    $Test = Test-NetConnection -ComputerName $Server -Port 9389 -WarningAction SilentlyContinue

    if ($Test.TcpTestSucceeded) {
        Write-Host "Success: TCP 9389 is reachable." -ForegroundColor Green
    }
    else {
        Write-Warning "Failed: TCP 9389 is not reachable. Try another DC or confirm ADWS is running."
    }

    Pause-Menu
}

function Check-Users {
    Clear-Host
    $UserInput = Read-Host "Enter user logon name(s), comma-separated. Example: testuser1, testuser2"
    $Users = $UserInput -split "," | ForEach-Object { $_.Trim() } | Where-Object { $_ }

    if (-not $Users) {
        Write-Warning "No users entered."
        Pause-Menu
        return
    }

    $Params = Get-OptionalServer

    foreach ($User in $Users) {
        Write-Host "`n==============================" -ForegroundColor Cyan
        Write-Host "User: $User" -ForegroundColor Cyan
        Write-Host "==============================" -ForegroundColor Cyan

        try {
            $ADUser = Get-ADUser -Identity $User -Properties msDS-ResultantPSO, DistinguishedName @Params -ErrorAction Stop

            Write-Host "`nUser object:" -ForegroundColor Yellow
            $ADUser | Select-Object SamAccountName, DistinguishedName, msDS-ResultantPSO | Format-List

            Write-Host "Resultant FGPP / PSO:" -ForegroundColor Yellow
            $PSO = Get-ADUserResultantPasswordPolicy -Identity $ADUser @Params -ErrorAction SilentlyContinue

            if ($PSO) {
                $PSO |
                    Select-Object Name, Precedence, ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold |
                    Format-List
            }
            else {
                Write-Warning "No FGPP / PSO returned. Showing default domain password policy."

                Get-ADDefaultDomainPasswordPolicy @Params |
                    Select-Object ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold |
                    Format-List
            }

            Write-Host "Group membership:" -ForegroundColor Yellow
            Get-ADPrincipalGroupMembership -Identity $User @Params |
                Select-Object Name, GroupCategory, GroupScope |
                Sort-Object Name |
                Format-Table -AutoSize
        }
        catch {
            Write-Warning "Failed for '$User': $($_.Exception.Message)"
            Write-Host "Suggestion: leave DC blank, try another DC, or confirm ADWS/TCP 9389 is reachable."
        }
    }

    Pause-Menu
}

function Check-DefaultPolicy {
    Clear-Host
    $Params = Get-OptionalServer

    try {
        Get-ADDefaultDomainPasswordPolicy @Params |
            Select-Object ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold |
            Format-List
    }
    catch {
        Write-Warning "Failed: $($_.Exception.Message)"
    }

    Pause-Menu
}

function Check-PSO {
    Clear-Host
    $Name = Read-Host "Enter FGPP / PSO name. Example: Admin Password Policy"

    if (-not $Name) {
        Write-Warning "No FGPP / PSO name entered."
        Pause-Menu
        return
    }

    $Params = Get-OptionalServer

    try {
        Write-Host "`nFGPP / PSO settings:" -ForegroundColor Yellow
        Get-ADFineGrainedPasswordPolicy -Identity $Name @Params |
            Select-Object Name, Precedence, ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold, AppliesTo |
            Format-List

        Write-Host "Directly applies to:" -ForegroundColor Yellow
        Get-ADFineGrainedPasswordPolicySubject -Identity $Name @Params |
            Select-Object Name, ObjectClass, DistinguishedName |
            Format-Table -AutoSize
    }
    catch {
        Write-Warning "Failed: $($_.Exception.Message)"
    }

    Pause-Menu
}

function Check-Group {
    Clear-Host
    $GroupName = Read-Host "Enter target group name. Example: AdminPasswordPolicyUsers"

    if (-not $GroupName) {
        Write-Warning "No group name entered."
        Pause-Menu
        return
    }

    $Params = Get-OptionalServer

    try {
        $Group = Get-ADGroup -Identity $GroupName -Properties GroupCategory, GroupScope, DistinguishedName @Params

        Write-Host "`nGroup details:" -ForegroundColor Yellow
        $Group | Select-Object Name, GroupCategory, GroupScope, DistinguishedName | Format-List

        if ($Group.GroupCategory -eq "Security" -and $Group.GroupScope -eq "Global") {
            Write-Host "Result: Group type is valid for FGPP targeting." -ForegroundColor Green
        }
        else {
            Write-Warning "Result: FGPP should target users or Global Security groups."
        }

        Write-Host "`nGroup members:" -ForegroundColor Yellow
        Get-ADGroupMember -Identity $GroupName @Params |
            Select-Object Name, SamAccountName, ObjectClass |
            Sort-Object Name |
            Format-Table -AutoSize
    }
    catch {
        Write-Warning "Failed: $($_.Exception.Message)"
    }

    Pause-Menu
}

do {
    Clear-Host
    Write-Host "AD Password Policy / FGPP Checker" -ForegroundColor Cyan
    Write-Host "--------------------------------"
    Write-Host "1. How to run"
    Write-Host "2. Test Domain Controller connectivity"
    Write-Host "3. Check user password policy"
    Write-Host "4. Show default domain password policy"
    Write-Host "5. Check FGPP / PSO assignment"
    Write-Host "6. Check target group"
    Write-Host "7. Exit"
    Write-Host ""

    $Choice = Read-Host "Select an option"

    switch ($Choice) {
        "1" { Show-Help }
        "2" { Test-DC }
        "3" { Check-Users }
        "4" { Check-DefaultPolicy }
        "5" { Check-PSO }
        "6" { Check-Group }
        "7" { Write-Host "Exiting." -ForegroundColor Green }
        default {
            Write-Warning "Invalid option. Choose 1-7."
            Pause-Menu
        }
    }
}
while ($Choice -ne "7")
