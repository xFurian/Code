<#
Title:
Active Directory Password Policy / FGPP Validation Helper

Purpose:
This script helps validate which password policy applies to one or more Active Directory users.

It can check:
1. How to run / what the prompts mean
2. Active Directory Web Services connectivity to a Domain Controller
3. Resultant Fine-Grained Password Policy for users
4. Default domain password policy
5. Fine-Grained Password Policy assignment
6. Target group type and membership

Plain-English notes:
- FGPP = Fine-Grained Password Policy
- PSO = Password Settings Object, which is the object behind an FGPP
- ADWS = Active Directory Web Services, required by many Active Directory PowerShell cmdlets
- DC = Domain Controller
- sAMAccountName = the older-style AD logon name, such as jsmith or blankpassword
#>

Import-Module ActiveDirectory -ErrorAction Stop

function Show-MainMenu {
    Clear-Host
    Write-Host "=====================================================" -ForegroundColor Cyan
    Write-Host " Active Directory Password Policy Validation Helper" -ForegroundColor Cyan
    Write-Host "=====================================================" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "Select which option to run:" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "1. How to run / explain what the script asks for"
    Write-Host "2. Test Domain Controller connectivity for AD PowerShell"
    Write-Host "3. Check password policy for one or more users"
    Write-Host "4. Show default domain password policy"
    Write-Host "5. Check a Fine-Grained Password Policy / PSO assignment"
    Write-Host "6. Check a target group type and membership"
    Write-Host "7. Run full validation"
    Write-Host "8. Exit"
    Write-Host ""
}

function Show-HowToRun {
    Clear-Host
    Write-Host "How to run this script" -ForegroundColor Cyan
    Write-Host "----------------------" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "Use this script from a machine that has:"
    Write-Host "- RSAT / Active Directory PowerShell module installed"
    Write-Host "- Network connectivity to a Domain Controller"
    Write-Host "- Permissions to read AD users, groups, and password policy objects"
    Write-Host ""
    Write-Host "Common inputs explained:" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "1. User sAMAccountName"
    Write-Host "   This is the AD logon name, not always the email address."
    Write-Host "   Example: blankpassword"
    Write-Host "   Example: hidefromgal"
    Write-Host ""
    Write-Host "   Where to find it:"
    Write-Host "   - Active Directory Users and Computers"
    Write-Host "   - User properties"
    Write-Host "   - Account tab"
    Write-Host "   - Field: User logon name pre-Windows 2000"
    Write-Host ""
    Write-Host "2. Domain Controller"
    Write-Host "   This is the server name of a DC."
    Write-Host "   Example: DC-P01.mrpm.sd42.ca"
    Write-Host ""
    Write-Host "   Where to find it:"
    Write-Host "   - Run: echo %LOGONSERVER%"
    Write-Host "   - Run: nltest /dclist:yourdomain.local"
    Write-Host "   - Or check Active Directory Sites and Services"
    Write-Host ""
    Write-Host "   Tip:"
    Write-Host "   - You can leave this blank and let PowerShell choose a DC."
    Write-Host "   - If one DC fails, try another DC."
    Write-Host ""
    Write-Host "3. Fine-Grained Password Policy / PSO name"
    Write-Host "   This is the name of the password settings object."
    Write-Host "   Example: Admin Accounts"
    Write-Host "   Example: LibraryUsers"
    Write-Host ""
    Write-Host "   Where to find it:"
    Write-Host "   - Active Directory Administrative Center"
    Write-Host "   - Domain"
    Write-Host "   - System"
    Write-Host "   - Password Settings Container"
    Write-Host ""
    Write-Host "4. Target group name"
    Write-Host "   This is the group the FGPP is directly assigned to."
    Write-Host "   Example: MRPM_Admin_PWPolicy"
    Write-Host ""
    Write-Host "   Where to find it:"
    Write-Host "   - Open the FGPP / PSO"
    Write-Host "   - Look under: Directly Applies To"
    Write-Host ""
    Write-Host "Important:"
    Write-Host "- Fine-Grained Password Policies apply to user objects and global security groups."
    Write-Host "- If a user does not return a resultant FGPP / PSO, that usually means no FGPP applies to that user."
    Write-Host "- In that case, the default domain password policy is the fallback policy to review."
    Write-Host ""
    Pause
}

function Get-CommonInputs {
    $Inputs = [ordered]@{}

    $Server = Read-Host "Enter Domain Controller name/FQDN, or press Enter to auto-select"
    if ($Server) {
        $Inputs.Server = $Server
    }

    $UseCredential = Read-Host "Use alternate credentials? Type Y for yes, or press Enter for current session"
    if ($UseCredential -eq "Y") {
        $Inputs.Credential = Get-Credential
    }

    return $Inputs
}

function Test-ADConnectivity {
    Clear-Host
    Write-Host "Test Domain Controller connectivity for AD PowerShell" -ForegroundColor Cyan
    Write-Host "-----------------------------------------------------" -ForegroundColor Cyan
    Write-Host ""

    $Server = Read-Host "Enter Domain Controller name/FQDN. Example: DC-P01.mrpm.sd42.ca"

    if (-not $Server) {
        Write-Warning "No Domain Controller was entered."
        Pause
        return
    }

    Write-Host ""
    Write-Host "Testing TCP 9389 to $Server..." -ForegroundColor Yellow
    Write-Host "TCP 9389 is used by Active Directory Web Services for AD PowerShell cmdlets." -ForegroundColor DarkGray

    try {
        $PortTest = Test-NetConnection -ComputerName $Server -Port 9389 -WarningAction SilentlyContinue

        if ($PortTest.TcpTestSucceeded) {
            Write-Host "SUCCESS: TCP 9389 is reachable on $Server." -ForegroundColor Green
        }
        else {
            Write-Warning "FAILED: TCP 9389 is not reachable on $Server."
            Write-Host ""
            Write-Host "Check the following:" -ForegroundColor Yellow
            Write-Host "- Is the Domain Controller online?"
            Write-Host "- Is the server name correct?"
            Write-Host "- Is Active Directory Web Services running on the DC?"
            Write-Host "- Is a firewall blocking TCP 9389?"
            Write-Host "- Try another Domain Controller."
        }
    }
    catch {
        Write-Warning "Connectivity test failed. Error: $($_.Exception.Message)"
    }

    Pause
}

function Check-UsersPasswordPolicy {
    Clear-Host
    Write-Host "Check password policy for one or more users" -ForegroundColor Cyan
    Write-Host "------------------------------------------" -ForegroundColor Cyan
    Write-Host ""

    Write-Host "Enter one or more AD user logon names." -ForegroundColor Yellow
    Write-Host "Example: blankpassword, hidefromgal"
    Write-Host ""

    $UserInput = Read-Host "User sAMAccountName value(s)"
    $Users = $UserInput -split "," | ForEach-Object { $_.Trim() } | Where-Object { $_ }

    if (-not $Users -or $Users.Count -eq 0) {
        Write-Warning "No users were entered."
        Pause
        return
    }

    $CommonParams = Get-CommonInputs

    foreach ($User in $Users) {
        Write-Host ""
        Write-Host "=====================================================" -ForegroundColor Cyan
        Write-Host "Checking user: $User" -ForegroundColor Cyan
        Write-Host "=====================================================" -ForegroundColor Cyan

        try {
            $ADUser = Get-ADUser `
                -Identity $User `
                -Properties msDS-ResultantPSO, DistinguishedName, userAccountControl `
                @CommonParams `
                -ErrorAction Stop
        }
        catch {
            Write-Warning "Could not retrieve user '$User'. Error: $($_.Exception.Message)"
            Write-Host ""
            Write-Host "Helpful checks:" -ForegroundColor Yellow
            Write-Host "- Confirm the sAMAccountName is correct."
            Write-Host "- Try leaving Domain Controller blank."
            Write-Host "- Try a different Domain Controller."
            Write-Host "- Confirm ADWS is reachable on TCP 9389."
            continue
        }

        Write-Host ""
        Write-Host "User object details:" -ForegroundColor Yellow
        $ADUser |
            Select-Object SamAccountName, DistinguishedName, userAccountControl, msDS-ResultantPSO |
            Format-List

        Write-Host ""
        Write-Host "Resultant Fine-Grained Password Policy / PSO:" -ForegroundColor Yellow

        try {
            $ResultantPSO = Get-ADUserResultantPasswordPolicy `
                -Identity $ADUser `
                @CommonParams `
                -ErrorAction Stop
        }
        catch {
            Write-Warning "Could not retrieve resultant password policy for '$User'. Error: $($_.Exception.Message)"
            $ResultantPSO = $null
        }

        if ($ResultantPSO) {
            $ResultantPSO |
                Select-Object `
                    Name,
                    Precedence,
                    ComplexityEnabled,
                    MinPasswordLength,
                    PasswordHistoryCount,
                    MinPasswordAge,
                    MaxPasswordAge,
                    LockoutThreshold,
                    LockoutObservationWindow,
                    LockoutDuration,
                    ReversibleEncryptionEnabled |
                Format-List
        }
        else {
            Write-Warning "No resultant Fine-Grained Password Policy / PSO was returned for '$User'."
            Write-Host ""
            Write-Host "Interpretation:" -ForegroundColor Yellow
            Write-Host "- This usually means no FGPP / PSO applies to this user."
            Write-Host "- The user should then be evaluated against the default domain password policy."
            Write-Host ""
            Write-Host "Default domain password policy:" -ForegroundColor Yellow

            try {
                Get-ADDefaultDomainPasswordPolicy @CommonParams -ErrorAction Stop |
                    Select-Object `
                        ComplexityEnabled,
                        MinPasswordLength,
                        PasswordHistoryCount,
                        MinPasswordAge,
                        MaxPasswordAge,
                        LockoutThreshold,
                        LockoutObservationWindow,
                        LockoutDuration,
                        ReversibleEncryptionEnabled |
                    Format-List
            }
            catch {
                Write-Warning "Could not retrieve default domain password policy. Error: $($_.Exception.Message)"
            }
        }

        Write-Host ""
        Write-Host "Effective group membership:" -ForegroundColor Yellow

        try {
            Get-ADPrincipalGroupMembership `
                -Identity $User `
                @CommonParams `
                -ErrorAction Stop |
                Select-Object Name, GroupCategory, GroupScope |
                Sort-Object Name |
                Format-Table -AutoSize
        }
        catch {
            Write-Warning "Could not retrieve group membership for '$User'. Error: $($_.Exception.Message)"
        }
    }

    Pause
}

function Show-DefaultDomainPasswordPolicy {
    Clear-Host
    Write-Host "Show default domain password policy" -ForegroundColor Cyan
    Write-Host "-----------------------------------" -ForegroundColor Cyan
    Write-Host ""

    $CommonParams = Get-CommonInputs

    try {
        Get-ADDefaultDomainPasswordPolicy @CommonParams -ErrorAction Stop |
            Select-Object `
                ComplexityEnabled,
                MinPasswordLength,
                PasswordHistoryCount,
                MinPasswordAge,
                MaxPasswordAge,
                LockoutThreshold,
                LockoutObservationWindow,
                LockoutDuration,
                ReversibleEncryptionEnabled |
            Format-List
    }
    catch {
        Write-Warning "Could not retrieve default domain password policy. Error: $($_.Exception.Message)"
    }

    Pause
}

function Check-PSOAssignment {
    Clear-Host
    Write-Host "Check Fine-Grained Password Policy / PSO assignment" -ForegroundColor Cyan
    Write-Host "--------------------------------------------------" -ForegroundColor Cyan
    Write-Host ""

    Write-Host "The PSO name is found in:" -ForegroundColor Yellow
    Write-Host "Active Directory Administrative Center > Domain > System > Password Settings Container"
    Write-Host ""
    Write-Host "Examples:"
    Write-Host "- Admin Accounts"
    Write-Host "- LibraryUsers"
    Write-Host ""

    $PsoName = Read-Host "Enter PSO / FGPP name"

    if (-not $PsoName) {
        Write-Warning "No PSO name was entered."
        Pause
        return
    }

    $CommonParams = Get-CommonInputs

    try {
        Write-Host ""
        Write-Host "PSO settings:" -ForegroundColor Yellow

        Get-ADFineGrainedPasswordPolicy `
            -Identity $PsoName `
            @CommonParams `
            -ErrorAction Stop |
            Select-Object `
                Name,
                Precedence,
                ComplexityEnabled,
                MinPasswordLength,
                PasswordHistoryCount,
                MinPasswordAge,
                MaxPasswordAge,
                LockoutThreshold,
                AppliesTo |
            Format-List

        Write-Host ""
        Write-Host "Users/groups directly assigned to this PSO:" -ForegroundColor Yellow

        Get-ADFineGrainedPasswordPolicySubject `
            -Identity $PsoName `
            @CommonParams `
            -ErrorAction Stop |
            Select-Object Name, ObjectClass, DistinguishedName |
            Format-Table -AutoSize
    }
    catch {
        Write-Warning "Could not validate PSO '$PsoName'. Error: $($_.Exception.Message)"
    }

    Pause
}

function Check-TargetGroup {
    Clear-Host
    Write-Host "Check target group type and membership" -ForegroundColor Cyan
    Write-Host "--------------------------------------" -ForegroundColor Cyan
    Write-Host ""

    Write-Host "The target group is found in the PSO under:" -ForegroundColor Yellow
    Write-Host "Directly Applies To"
    Write-Host ""
    Write-Host "Example from the screenshot:"
    Write-Host "MRPM_Admin_PWPolicy"
    Write-Host ""

    $GroupName = Read-Host "Enter group name"

    if (-not $GroupName) {
        Write-Warning "No group name was entered."
        Pause
        return
    }

    $CommonParams = Get-CommonInputs

    try {
        Write-Host ""
        Write-Host "Group details:" -ForegroundColor Yellow

        $Group = Get-ADGroup `
            -Identity $GroupName `
            -Properties GroupCategory, GroupScope, DistinguishedName `
            @CommonParams `
            -ErrorAction Stop

        $Group |
            Select-Object Name, GroupCategory, GroupScope, DistinguishedName |
            Format-List

        Write-Host ""
        Write-Host "Interpretation:" -ForegroundColor Yellow

        if ($Group.GroupCategory -eq "Security" -and $Group.GroupScope -eq "Global") {
            Write-Host "This group is a Global Security group. That is the expected type for FGPP targeting." -ForegroundColor Green
        }
        else {
            Write-Warning "This group is not a Global Security group. FGPP targeting may not apply as expected through this group."
        }

        Write-Host ""
        Write-Host "Group members:" -ForegroundColor Yellow

        Get-ADGroupMember `
            -Identity $GroupName `
            @CommonParams `
            -ErrorAction Stop |
            Select-Object Name, SamAccountName, ObjectClass |
            Sort-Object Name |
            Format-Table -AutoSize
    }
    catch {
        Write-Warning "Could not validate group '$GroupName'. Error: $($_.Exception.Message)"
    }

    Pause
}

function Run-FullValidation {
    Clear-Host
    Write-Host "Run full validation" -ForegroundColor Cyan
    Write-Host "-------------------" -ForegroundColor Cyan
    Write-Host ""

    Write-Host "This will ask for:" -ForegroundColor Yellow
    Write-Host "1. One or more users"
    Write-Host "2. Domain Controller, optional"
    Write-Host "3. PSO / FGPP name, optional"
    Write-Host "4. Target group name, optional"
    Write-Host ""

    $UserInput = Read-Host "Enter one or more user sAMAccountNames, separated by commas"
    $Users = $UserInput -split "," | ForEach-Object { $_.Trim() } | Where-Object { $_ }

    $Server = Read-Host "Enter Domain Controller name/FQDN, or press Enter to auto-select"
    $PsoName = Read-Host "Enter PSO / FGPP name, or press Enter to skip"
    $GroupName = Read-Host "Enter FGPP target group name, or press Enter to skip"

    $UseCredential = Read-Host "Use alternate credentials? Type Y for yes, or press Enter for current session"

    $CommonParams = @{}

    if ($Server) {
        $CommonParams.Server = $Server

        Write-Host ""
        Write-Host "Testing TCP 9389 to $Server..." -ForegroundColor Yellow

        try {
            $PortTest = Test-NetConnection -ComputerName $Server -Port 9389 -WarningAction SilentlyContinue

            if ($PortTest.TcpTestSucceeded) {
                Write-Host "SUCCESS: TCP 9389 is reachable on $Server." -ForegroundColor Green
            }
            else {
                Write-Warning "FAILED: TCP 9389 is not reachable on $Server. AD PowerShell commands may fail against this DC."
            }
        }
        catch {
            Write-Warning "Could not test TCP 9389. Continuing anyway."
        }
    }

    if ($UseCredential -eq "Y") {
        $CommonParams.Credential = Get-Credential
    }

    if ($Users -and $Users.Count -gt 0) {
        foreach ($User in $Users) {
            Write-Host ""
            Write-Host "=====================================================" -ForegroundColor Cyan
            Write-Host "Checking user: $User" -ForegroundColor Cyan
            Write-Host "=====================================================" -ForegroundColor Cyan

            try {
                $ADUser = Get-ADUser `
                    -Identity $User `
                    -Properties msDS-ResultantPSO, DistinguishedName, userAccountControl `
                    @CommonParams `
                    -ErrorAction Stop

                Write-Host ""
                Write-Host "User object details:" -ForegroundColor Yellow
                $ADUser |
                    Select-Object SamAccountName, DistinguishedName, userAccountControl, msDS-ResultantPSO |
                    Format-List

                Write-Host ""
                Write-Host "Resultant Fine-Grained Password Policy / PSO:" -ForegroundColor Yellow

                $ResultantPSO = Get-ADUserResultantPasswordPolicy `
                    -Identity $ADUser `
                    @CommonParams `
                    -ErrorAction SilentlyContinue

                if ($ResultantPSO) {
                    $ResultantPSO |
                        Select-Object Name, Precedence, ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold |
                        Format-List
                }
                else {
                    Write-Warning "No resultant FGPP / PSO returned for '$User'. Showing default domain policy."

                    Get-ADDefaultDomainPasswordPolicy @CommonParams -ErrorAction Stop |
                        Select-Object ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold |
                        Format-List
                }

                Write-Host ""
                Write-Host "Effective group membership:" -ForegroundColor Yellow

                Get-ADPrincipalGroupMembership `
                    -Identity $User `
                    @CommonParams `
                    -ErrorAction Stop |
                    Select-Object Name, GroupCategory, GroupScope |
                    Sort-Object Name |
                    Format-Table -AutoSize
            }
            catch {
                Write-Warning "Validation failed for user '$User'. Error: $($_.Exception.Message)"
            }
        }
    }

    if ($PsoName) {
        Write-Host ""
        Write-Host "=====================================================" -ForegroundColor Cyan
        Write-Host "Checking PSO / FGPP: $PsoName" -ForegroundColor Cyan
        Write-Host "=====================================================" -ForegroundColor Cyan

        try {
            Get-ADFineGrainedPasswordPolicy `
                -Identity $PsoName `
                @CommonParams `
                -ErrorAction Stop |
                Select-Object Name, Precedence, ComplexityEnabled, MinPasswordLength, PasswordHistoryCount, MinPasswordAge, MaxPasswordAge, LockoutThreshold, AppliesTo |
                Format-List

            Write-Host ""
            Write-Host "Direct PSO subjects:" -ForegroundColor Yellow

            Get-ADFineGrainedPasswordPolicySubject `
                -Identity $PsoName `
                @CommonParams `
                -ErrorAction Stop |
                Select-Object Name, ObjectClass, DistinguishedName |
                Format-Table -AutoSize
        }
        catch {
            Write-Warning "PSO validation failed. Error: $($_.Exception.Message)"
        }
    }

    if ($GroupName) {
        Write-Host ""
        Write-Host "=====================================================" -ForegroundColor Cyan
        Write-Host "Checking target group: $GroupName" -ForegroundColor Cyan
        Write-Host "=====================================================" -ForegroundColor Cyan

        try {
            $Group = Get-ADGroup `
                -Identity $GroupName `
                -Properties GroupCategory, GroupScope, DistinguishedName `
                @CommonParams `
                -ErrorAction Stop

            $Group |
                Select-Object Name, GroupCategory, GroupScope, DistinguishedName |
                Format-List

            if ($Group.GroupCategory -eq "Security" -and $Group.GroupScope -eq "Global") {
                Write-Host "Group type check passed: Global Security group." -ForegroundColor Green
            }
            else {
                Write-Warning "Group type check failed: FGPP should target users or Global Security groups."
            }

            Write-Host ""
            Write-Host "Group members:" -ForegroundColor Yellow

            Get-ADGroupMember `
                -Identity $GroupName `
                @CommonParams `
                -ErrorAction Stop |
                Select-Object Name, SamAccountName, ObjectClass |
                Sort-Object Name |
                Format-Table -AutoSize
        }
        catch {
            Write-Warning "Group validation failed. Error: $($_.Exception.Message)"
        }
    }

    Pause
}

do {
    Show-MainMenu
    $Selection = Read-Host "Enter selection number"

    switch ($Selection) {
        "1" { Show-HowToRun }
        "2" { Test-ADConnectivity }
        "3" { Check-UsersPasswordPolicy }
        "4" { Show-DefaultDomainPasswordPolicy }
        "5" { Check-PSOAssignment }
        "6" { Check-TargetGroup }
        "7" { Run-FullValidation }
        "8" { Write-Host "Exiting." -ForegroundColor Green }
        default {
            Write-Warning "Invalid selection. Choose 1 through 8."
            Pause
        }
    }
}
while ($Selection -ne "8")
